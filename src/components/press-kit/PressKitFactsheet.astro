---
import type { SupportedLang } from "../../i18n/ui";
import { useTranslations } from "../../i18n/utils";

interface Props {
  lang: SupportedLang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const factsheetItems = [
  {
    label: t("presskit.sidebar.developer") as string,
    value: "Rave Team",
    icon: "M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5",
  },
  {
    label: t("presskit.sidebar.publisher") as string,
    value: "Rave Team",
    icon: "M19 21l-7-5-7 5V5a2 2 0 012-2h10a2 2 0 012 2z",
  },
  {
    label: t("presskit.sidebar.platforms") as string,
    value: "PC (Win, Mac, Linux)",
    icon: "M20 16V7a2 2 0 00-2-2H6a2 2 0 00-2 2v9m16 0H4m16 0l1.28 2.55a1 1 0 01-.9 1.45H3.62a1 1 0 01-.9-1.45L4 16",
  },
  {
    label: t("presskit.sidebar.social") as string,
    value: "@raveteamgames",
    href: "#contact",
    icon: "M16 8a6 6 0 01-12 0 M22 4s-4 0-4-4M17.5 8a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z",
  },
  {
    label: t("presskit.sidebar.contact") as string,
    value: "contact@raveteam.games",
    href: "mailto:contact@raveteam.games",
    icon: "M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z",
  },
];
---

<div>
  <div class="h-[3px] rainbow-border"></div>

  <div class="bg-primary border-b border-white/10 py-6 lg:py-8">
    <div class="max-w-5xl mx-auto px-4">
      <dl
        class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 lg:gap-6"
      >
        {
          factsheetItems.map((item) => (
            <div class="flex flex-col gap-1.5">
              <div class="flex items-center gap-2">
                <svg
                  class="w-3.5 h-3.5 text-[#00FFF9] shrink-0"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                >
                  <path d={item.icon} />
                </svg>
                <dt class="text-[#00FFF9] font-bold text-[10px] uppercase tracking-[0.2em]">
                  {item.label}
                </dt>
              </div>
              <dd class="text-white/90 text-sm pl-[22px]">
                {item.href ? (
                  <a
                    href={item.href}
                    class="relative inline-block text-white hover:text-secondary transition-colors duration-200 after:absolute after:bottom-0 after:left-0 after:h-[1.5px] after:w-0 after:bg-secondary after:transition-all after:duration-300 hover:after:w-full"
                  >
                    {item.value}
                  </a>
                ) : (
                  item.value
                )}
              </dd>
            </div>
          ))
        }
      </dl>
    </div>
  </div>
</div>
