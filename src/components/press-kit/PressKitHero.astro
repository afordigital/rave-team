---
---

<section id="hero" class="relative h-[320px] sm:h-[420px] lg:h-[480px] overflow-hidden">
  <img
    class="absolute inset-0 w-full h-full object-cover"
    src="/images/Arte_SPACEDIVA.png"
    alt="Space Diva Background Art"
  />
  <div class="absolute inset-0 bg-primary/60"></div>
  <div
    class="pointer-events-none absolute inset-x-0 top-0 h-32 bg-linear-to-b from-primary/80 to-transparent z-10"
  >
  </div>
  <div
    class="pointer-events-none absolute inset-x-0 bottom-0 h-40 bg-linear-to-t from-[#1a1525] to-transparent z-10"
  >
  </div>

  <div
    class="relative z-20 h-full max-w-4xl mx-auto px-4 flex flex-col items-center justify-center text-center gap-6"
  >
    <img
      src="/images/press-kit/logos/spacediva-logo.webp"
      alt="Space Diva Logo"
      class="h-24 sm:h-36 lg:h-48 w-auto object-contain drop-shadow-[0_4px_12px_rgba(0,0,0,0.5)]"
    />
    <h1
      class="font-luckiest-guy text-hero-title text-white text-shadow-[6px_6px_0_rgba(0,0,0,1)] tracking-wider"
    >
      PRESS KIT
    </h1>
  </div>

  <div
    class="pointer-events-none absolute top-16 left-[10%] w-3 h-3 bg-[#00FFF9] rounded-full opacity-40 animate-pulse"
  >
  </div>
  <div
    class="pointer-events-none absolute top-32 right-[15%] w-2 h-2 bg-secondary rounded-full opacity-30 animate-pulse"
    style="animation-delay: 1s;"
  >
  </div>
  <div
    class="pointer-events-none absolute bottom-28 left-[20%] w-2.5 h-2.5 bg-[#B485FF] rounded-full opacity-35 animate-pulse"
    style="animation-delay: 2s;"
  >
  </div>
</section>
