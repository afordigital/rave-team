---
interface Props {
  heading: string;
}

const { heading } = Astro.props;

const YOUTUBE_VIDEO_ID = "LzBF4DQ23CA";
---

<section class="mb-14">
  <h2
    class="font-luckiest-guy text-section-title theme-shadow-text text-white mb-6"
  >
    {heading}
  </h2>
  <div class="relative group">
    <div
      class="absolute -inset-[3px] rounded-lg trailer-glow opacity-60 group-hover:opacity-100 transition-opacity duration-500"
    >
    </div>
    <div class="absolute inset-0 translate-x-2 translate-y-2 bg-black/40 rounded-lg"></div>
    <div
      class="relative aspect-video w-full rounded-lg overflow-hidden border-2 border-white/20"
    >
      <iframe
        src={`https://www.youtube.com/embed/${YOUTUBE_VIDEO_ID}`}
        title={heading}
        loading="lazy"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        class="w-full h-full relative z-10"
      ></iframe>
    </div>
  </div>
</section>

<style>
  .trailer-glow {
    background: linear-gradient(135deg, #00fff9, #c31c96, #b485ff, #00fff9);
    background-size: 300% 300%;
    animation: glow-shift 6s ease-in-out infinite;
    filter: blur(6px);
  }

  @keyframes glow-shift {
    0%,
    100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }
</style>
