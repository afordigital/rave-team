<section
  id="contact"
  class="text-white py-12 flex flex-col lg:flex-row-reverse gap-24 items-stretch max-w-6xl w-full mx-auto px-4 scroll-mt-16"
>
  <!-- Texto lateral -->
  <article class="flex flex-col gap-y-1 basis-full lg:basis-1/2">
    <hgroup class="flex flex-col text-left gap-y-1">
      <h2 class="text-section-title font-luckiest-guy">Want to invest?</h2>
      <p class="text-xl">We're not going to say no, message us 😊</p>
    </hgroup>
  </article>

  <!-- Formulario -->
  <form
    id="form"
    method="POST"
    novalidate
    data-astro-reload
    action="https://api.web3forms.com/submit"
    class="needs-validation flex flex-col gap-4 w-full basis-full lg:basis-1/2"
  >
    <input
      type="hidden"
      name="access_key"
      value={import.meta.env.WEB3FORMS_API_KEY}
    />

    <input
      type="checkbox"
      class="hidden"
      style="display:none"
      name="botcheck"
    />

    <label
      class="py-3 px-4 shadow-[4px_2px_0_rgba(250,250,250,1)] border border-white"
    >
      <input
        name="name"
        type="text"
        placeholder="Introduce your name"
        class="outline-none placeholder:text-[#E1E1E1] bg-transparent w-full"
      />
    </label>

    <label
      class="py-3 px-4 shadow-[4px_2px_0_rgba(250,250,250,1)] border border-white"
    >
      <input
        required
        id="email_address"
        type="email"
        name="email"
        placeholder="Introduce your email*"
        class="outline-none placeholder:text-[#E1E1E1] bg-transparent w-full"
      />
    </label>

    <label
      class="py-3 px-4 shadow-[4px_2px_0_rgba(250,250,250,1)] border border-white"
    >
      <textarea
        name="message"
        placeholder="Drop your message here, like it's hot 🔥"
        class="outline-none w-full min-h-[50px] max-h-[150px] placeholder:text-[#E1E1E1] bg-transparent"
      ></textarea>
    </label>

    <div class="w-full">
      <div
        id="captcha-container"
        class="h-captcha justify-center hidden"
        data-captcha="true"
        data-lang="en"
        data-theme="dark"
      >
      </div>
    </div>

    <div class="flex items-start gap-2 text-xs text-gray-200">
      <input
        id="legal-consent"
        name="legal_consent"
        type="checkbox"
        required
        class="mt-1 h-4 w-4 rounded border-gray-400 bg-transparent text-primary focus:ring-2 focus:ring-offset-0 focus:ring-white"
      />
      <label for="legal-consent" class="flex-1">
        He leído y acepto la información legal.
      </label>
      <div class="relative group ml-1">
        <button
          id="legal-info-button"
          type="button"
          aria-label="Más información legal"
          aria-describedby="legal-tooltip"
          class="flex h-5 w-5 items-center justify-center rounded-full border border-gray-300 text-[10px] font-bold text-gray-200 bg-transparent hover:bg-white hover:text-primary transition-colors"
        >
          i
        </button>
        <div
          id="legal-tooltip"
          role="tooltip"
          class="absolute left-1/2 top-7 z-20 hidden w-64 -translate-x-1/2 rounded-md border border-gray-300 bg-white p-3 text-[11px] text-black shadow-lg group-hover:block"
        >
          Aquí irá la información legal que me pases.
        </div>
      </div>
    </div>

    <button
      type="submit"
      class="bg-white px-[50px] w-full py-4 text-primary font-luckiest-guy text-xl transition duration-150 ease-in-out input-button cursor-pointer"
    >
      Send Message
    </button>

    <div id="result" class="mt-3 text-center"></div>
  </form>

  <script src="https://web3forms.com/client/script.js" async defer></script>
</section>

<style>
  .input-button {
    box-shadow: 5px 5px 0 0 #ededed;
    transition:
      box-shadow 0.15s ease-in-out,
      transform 0.15s ease-in-out;
  }

  .input-button:hover {
    transform: none;
    box-shadow: none;
  }
</style>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const form = document.getElementById("form");
    const result = document.getElementById("result");
    const captcha = document.getElementById("captcha-container");
    const legalInfoButton = document.getElementById("legal-info-button");
    const legalTooltip = document.getElementById("legal-tooltip");

    if (legalInfoButton && legalTooltip) {
      legalInfoButton.addEventListener("click", (event) => {
        event.preventDefault();
        event.stopPropagation();
        legalTooltip.classList.toggle("hidden");
      });

      document.addEventListener("click", (event) => {
        if (
          !legalTooltip.classList.contains("hidden") &&
          event.target instanceof Node &&
          !legalTooltip.contains(event.target) &&
          event.target !== legalInfoButton
        ) {
          legalTooltip.classList.add("hidden");
        }
      });
    }

    let captchaTriggered = false;

    form.addEventListener("submit", function (e) {
      e.preventDefault();
      form.classList.add("was-validated");

      if (!form.checkValidity()) {
        form.querySelectorAll(":invalid")[0].focus();
        return;
      }

      if (!captchaTriggered) {
        captcha.classList.remove("hidden");
        captchaTriggered = true;
        return;
      }

      const formData = new FormData(form);
      const object = Object.fromEntries(formData);
      const json = JSON.stringify(object);

      result.innerHTML = "Sending...";

      fetch("https://api.web3forms.com/submit", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Accept: "application/json",
        },
        body: json,
      })
        .then(async (response) => {
          let json = await response.json();
          if (response.status == 200) {
            result.classList.add("text-green-500");
            result.innerHTML = json.message;
          } else {
            console.log(response);
            result.classList.add("text-red-500");
            result.innerHTML = json.message;
          }
        })
        .catch((error) => {
          console.log(error);
          result.innerHTML = "Something went wrong!";
        })
        .then(function () {
          form.reset();
          form.classList.remove("was-validated");
          captcha.classList.add("hidden");
          captchaTriggered = false;
          setTimeout(() => {
            result.style.display = "none";
          }, 5000);
        });
    });
  });
</script>
