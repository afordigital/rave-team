---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import PressKitHero from "../../components/press-kit/PressKitHero.astro";
import PressKitFactsheet from "../../components/press-kit/PressKitFactsheet.astro";
import PressKitContent from "../../components/press-kit/PressKitContent.astro";
import type { SupportedLang } from "../../i18n/ui";
import { useTranslations } from "../../i18n/utils";
import { BASE_URL } from "../../data/consts";

export function getStaticPaths() {
  return [
    { params: { lang: undefined }, props: { lang: "en" as SupportedLang } },
    { params: { lang: "es" }, props: { lang: "es" as SupportedLang } },
  ];
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const title = t("presskit.title") as string;
const description = t("presskit.meta.description") as string;

const siteUrl = BASE_URL || Astro.url.origin;
---

<BaseLayout {title} {description} lang={lang}>
  <Fragment slot="head">
    <link rel="alternate" hreflang="en" href={`${siteUrl}/press-kit`} />
    <link rel="alternate" hreflang="es" href={`${siteUrl}/es/press-kit`} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/press-kit`} />
  </Fragment>

  <Navbar />
  <PressKitHero />
  <PressKitFactsheet {lang} />

  <main class="relative text-white overflow-hidden pk-content-bg">
    <div
      class="pointer-events-none absolute top-48 -left-32 w-72 h-72 rounded-full opacity-[0.06]"
      style="background: radial-gradient(circle, #00FFF9 0%, transparent 70%);"
    >
    </div>
    <div
      class="pointer-events-none absolute top-[800px] -right-24 w-56 h-56 rounded-full opacity-[0.04]"
      style="background: radial-gradient(circle, #c31c96 0%, transparent 70%);"
    >
    </div>
    <div
      class="pointer-events-none absolute bottom-96 -left-16 w-44 h-44 rounded-full opacity-[0.04]"
      style="background: radial-gradient(circle, #B485FF 0%, transparent 70%);"
    >
    </div>

    <div class="relative max-w-4xl mx-auto px-4 py-16 lg:py-20">
      <PressKitContent {lang} />
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .pk-content-bg {
    background: linear-gradient(180deg, #1a1525 0%, #272035 8%, #272035 100%);
  }
</style>
